import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int T = sc.nextInt();
        int S = sc.nextInt();
        int B = sc.nextInt();

        int bytes = 2 * T * S * B * 512;
        int kb = bytes / 1024;

        System.out.println(kb + " KB");
    }
}
