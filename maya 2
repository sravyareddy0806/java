import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int x = sc.nextInt();
        int y = sc.nextInt();

        double hypotenuse = Math.sqrt(x * x + y * y);

        System.out.printf("%.2f", hypotenuse);
    }
}
