import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int c = sc.nextInt();   // Celsius value

        double f = 32 + (c * 9.0 / 5.0);  // Fahrenheit formula

        System.out.printf("%.2f", f); // print with 2 decimal places

        sc.close();
    }
}
